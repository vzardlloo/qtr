{
  "name": "@vzard/qtr",
  "version": "0.1.2",
  "description": "A tiny, fast translation tool for the terminal.",
  "keywords": [
    "cli",
    "translation",
    "translator",
    "tui",
    "ink",
    "react",
    "terminal"
  ],
  "homepage": "https://github.com/vzardlloo/qtr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vzardlloo/qtr.git"
  },
  "bugs": {
    "url": "https://github.com/vzardlloo/qtr/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "qtr": "./build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 node --import=tsx src/index.tsx",
    "build": "node ./node_modules/typescript/bin/tsc",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "npm run build",
    "start": "node build/index.js"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "tencentcloud-sdk-nodejs": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
